{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "name": { "type": "string", "description": "Display name of the user" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "photoURL": { "type": "string", "description": "User profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when the profile was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when the profile was last updated" }
      },
      "required": ["uid", "name", "email", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles collection indexed by userId"
    }
  }
}
