rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Model Validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 6 && // uid, name, email, photoURL, createdAt, updatedAt
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      allow update: if isOwner(userId) &&
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid &&
                      incoming().email == existing().email &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL', 'updatedAt']);
      
      allow delete: if false; // Users cannot delete their own profiles via client
    }
  }
}
